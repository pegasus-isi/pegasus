#!/bin/bash
# Build a Pegasus .rpm package from the current source tree.
# Expected to run on a RHEL/Rocky Linux host with build dependencies installed
# (rpm-build, systemd-rpm-macros, cmake, java-*-openjdk-devel, python3.12-*, etc.
# — see pegasus.spec.in BuildRequires).
#
# The RHEL major version is detected from the running system automatically.
#
# Usage: release-tools/build-rpms
# Output: dist/rpm/

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOP_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$TOP_DIR"

if [ ! -e pyproject.toml ]; then
    echo "ERROR: This does not look like a Pegasus source directory (pyproject.toml not found)."
    exit 1
fi

# Detect RHEL major version from the running system
RHEL_VERSION=$(rpm -E '%{rhel}' 2>/dev/null)
if [ -z "$RHEL_VERSION" ] || [ "$RHEL_VERSION" = "%{rhel}" ]; then
    RHEL_VERSION=$(. /etc/os-release 2>/dev/null && echo "${VERSION_ID%%.*}" || echo "9")
fi

VERSION=$(grep '^pegasus.version' build.properties | cut -d= -f2 | tr -d ' ')
RPM_VERSION=$(echo "$VERSION" | tr '-' '.')
DATE_RPM=$(date +'%a %b %d %Y')
echo "Building pegasus $RPM_VERSION for RHEL ${RHEL_VERSION}..."

RPM_DIR=$(mktemp -d)
trap "rm -rf $RPM_DIR" EXIT
mkdir -p "$RPM_DIR"/{BUILD,BUILDROOT,RPMS,SOURCES,SPECS,SRPMS}

echo "--- Creating source tarball ---"
tar czf "$RPM_DIR/SOURCES/pegasus-${RPM_VERSION}.tar.gz" \
    --transform "s|^\./|pegasus-${RPM_VERSION}/|" \
    --exclude=./.git \
    --exclude=./_cmake_build \
    --exclude=./_build_venv \
    --exclude=./dist \
    --exclude=./debian/pegasus \
    .

echo "--- Preparing spec file ---"
sed \
    -e "s/@PEGASUS_VERSION@/$RPM_VERSION/g" \
    -e "s/@DATE@/$DATE_RPM/g" \
    pegasus.spec.in > "$RPM_DIR/SPECS/pegasus.spec"

echo "--- Running rpmbuild ---"
rpmbuild -bb \
    --define "_topdir $RPM_DIR" \
    --define "rhel ${RHEL_VERSION}" \
    "$RPM_DIR/SPECS/pegasus.spec"

mkdir -p dist/rpm
find "$RPM_DIR/RPMS" -name "*.rpm" -exec cp {} dist/rpm/ \;
echo "--- Built packages ---"
ls -lh dist/rpm/pegasus-*.rpm 2>/dev/null || true
