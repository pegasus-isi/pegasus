#!/bin/bash

# This script generates a requirements.txt file for the pegasus-wms packages
# specific to the supported Python versions. It ignores packages that are to
# be installed externally, like PyYAML, and cryptography.

set -euo pipefail

DIR=$(cd "$(dirname "$0")/.." && pwd)
UV=${UV:-uv}
REQUIREMENTS="$DIR/src/requirements.txt"

WORKER_PACKAGE=(packages/pegasus-worker)
PACKAGES=(
    packages/pegasus-worker
    packages/pegasus-python
    packages/pegasus-api
    packages/pegasus-common
)

EXCLUDED_PACKAGES=(
    pegasus-wms
    pegasus-wms.api
    pegasus-wms.common
    pegasus-wms.worker
    PyYAML
    cryptography
    cffi
    pycparser
)

if ! command -v "$UV" >/dev/null 2>&1; then
    echo "ERROR: uv is required to update requirements.txt" >&2
    exit 1
fi

TMP_DIR=$(mktemp -d "${TMPDIR:-/tmp}/pegasus-requirements.XXXXXX")
trap 'rm -rf "$TMP_DIR"' EXIT

cd "$DIR"
rm -f "$REQUIREMENTS"
for i in {6..14}; do
    PYTHON_VERSION="3.$i"
    echo "# ------- Python $PYTHON_VERSION -------" | tee -a "$REQUIREMENTS"

    REQUIREMENTS_IN="$TMP_DIR/requirements-$PYTHON_VERSION.in"
    COMPILED_REQUIREMENTS="$TMP_DIR/requirements-$PYTHON_VERSION.txt"

    : > "$REQUIREMENTS_IN"
    # Only pegasus-worker still supports Python < 3.10.
    if [[ "$i" -lt 10 ]]; then
        printf "%s\n" "${WORKER_PACKAGE[@]}" > "$REQUIREMENTS_IN"
    else
        printf "%s\n" "${PACKAGES[@]}" > "$REQUIREMENTS_IN"
    fi

    UV_ARGS=()
    for package in "${EXCLUDED_PACKAGES[@]}"; do
        UV_ARGS+=(--no-emit-package "$package")
    done

    "$UV" pip compile "$REQUIREMENTS_IN" \
        --python-version "$PYTHON_VERSION" \
        --no-header \
        --no-annotate \
        "${UV_ARGS[@]}" \
        --output-file "$COMPILED_REQUIREMENTS"

    awk -v python_version="$PYTHON_VERSION" '
        NF && $1 !~ /^#/ {
            printf "%s;python_version==\047%s\047\n", $0, python_version
        }
    ' "$COMPILED_REQUIREMENTS" >> "$REQUIREMENTS"
done
