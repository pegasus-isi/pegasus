#!/bin/bash
# Build a Pegasus .deb package from the current source tree.
# Expected to run on a Debian/Ubuntu host with build dependencies installed
# (debhelper, cmake, openjdk-*-jdk, python3-venv, etc. — see debian/control).
#
# Usage: release-tools/build-deb
# Output: dist/deb/

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOP_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$TOP_DIR"

if [ ! -e pyproject.toml ]; then
    echo "ERROR: This does not look like a Pegasus source directory (pyproject.toml not found)."
    exit 1
fi

VERSION=$(grep '^pegasus.version' build.properties | cut -d= -f2 | tr -d ' ')
BASEVER=$(echo "$VERSION" | perl -pe 's/([0-9]+\.[0-9]+\.[0-9]+).*/\1/')
EXTRAVER=$(echo "$VERSION" | perl -pe 's/[0-9]+\.[0-9]+\.[0-9]+//')
if [ -n "$EXTRAVER" ]; then
    EXTRAVER="${EXTRAVER}$(date +'%Y%m%d%H%M')"
    PACKAGE_VERSION="${BASEVER}~${EXTRAVER}"
else
    PACKAGE_VERSION="$VERSION"
fi

OSID="ubuntu$(lsb_release -rs | cut -d. -f1)"
DATE_DEB=$(date -R)

cp debian/changelog.in debian/changelog
perl -pi -e "s/\@PEGASUS_VERSION\@/$PACKAGE_VERSION/g" debian/changelog
perl -pi -e "s/\@DATE\@/$DATE_DEB/g" debian/changelog
perl -pi -e "s/\@OSID\@/$OSID/g" debian/changelog

echo "Building pegasus $PACKAGE_VERSION ($OSID)..."
dpkg-buildpackage -b -uc --compression=gzip

# dpkg-buildpackage writes output to the parent of the source tree
mkdir -p dist/deb
find "$TOP_DIR/.." -maxdepth 1 \( -name "pegasus_*.deb" -o -name "pegasus_*.changes" \) \
    -exec cp {} dist/deb/ \;
echo "--- Built packages ---"
ls -lh dist/deb/pegasus_*.deb 2>/dev/null || true
