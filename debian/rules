#!/usr/bin/make -f
# -*- makefile -*-

export DH_VERBOSE=1

PYTHON3 := python3


# Build .deb with gzip compression (compatible with older apt)
# https://stackoverflow.com/questions/71196872/how-do-i-build-a-deb-without-zstd-compression-in-ubuntu-21-10
override_dh_builddeb:
	dh_builddeb -- -Zgzip


build: build-stamp


build-stamp:
	dh_testdir

	# Install build tooling into a temporary virtualenv (not available as distro packages)
	$(PYTHON3) -m venv _build_venv
	_build_venv/bin/pip install --upgrade pip scikit-build-core build

	# Build the wheel (includes worker tarball + C tools + Java JARs via cmake)
	PYTHON=_build_venv/bin/python make build

	touch build-stamp


install: build
	dh_testdir
	dh_testroot
	dh_prep
	dh_installdirs

	# Install wheel and all runtime Python deps into the staging area.
	# We bundle deps rather than declare apt equivalents because several
	# (pamela, pika, globus-sdk, boto3, Flask-Caching) have no apt package.
	_build_venv/bin/pip install \
	    --ignore-installed \
	    --prefix=$(CURDIR)/debian/pegasus/usr \
	    dist/pegasus_wms-*.whl

	# Debian's Python looks in dist-packages, not site-packages.
	# Rename the directory pip creates so the installed packages are importable.
	$(eval PY_VER := $(shell $(PYTHON3) -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')"))
	if [ -d "$(CURDIR)/debian/pegasus/usr/lib/python$(PY_VER)/site-packages" ]; then \
	    mv "$(CURDIR)/debian/pegasus/usr/lib/python$(PY_VER)/site-packages" \
	       "$(CURDIR)/debian/pegasus/usr/lib/python$(PY_VER)/dist-packages"; \
	fi

	# Strip C executables
	-strip debian/pegasus/usr/bin/pegasus-kickstart
	-strip debian/pegasus/usr/bin/pegasus-cluster
	-strip debian/pegasus/usr/bin/pegasus-keg

	# Install systemd service unit from source tree
	install -d debian/pegasus/lib/systemd/system
	install -m 0644 share/pegasus/systemd-unit/pegasus-service.service \
	    debian/pegasus/lib/systemd/system/

	# Fix shebangs: pip writes the build-venv path; replace with system python3
	find debian/pegasus/usr/bin -type f \
	    -exec sed -i '1s|^#!.*/python[^ ]*|#!/usr/bin/python3|' {} \;

	# Remove pyc files and __pycache__
	find debian/pegasus/ -name \*.pyc -exec rm {} \;
	find debian/pegasus/ -depth -name __pycache__ -exec rm -rf {} \;


# Build architecture-independent files here.
binary-indep: build install
	# We have nothing to do by default.

# Build architecture-dependent files here.
binary-arch: build install
	dh_testdir
	dh_testroot
	dh_installchangelogs
	dh_installdocs
	dh_installman
	dh_compress
	dh_fixperms
	dh_installdeb
	dh_shlibdeps
	dh_gencontrol
	dh_md5sums
	dh_builddeb


binary: binary-indep binary-arch


clean:
	dh_testdir
	dh_testroot
	rm -f build-stamp
	make clean
	rm -rf _build_venv
	dh_clean


%:
	echo "dh $@"
	exit 1


.PHONY: build binary-indep binary-arch binary install clean
