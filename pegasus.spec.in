Name:           pegasus
Version:        @PEGASUS_VERSION@
Release:        1%{?dist}
Summary:        Workflow management system for HTCondor, grids, and clouds
Group:          Applications/System
License:        ASL 2.0
URL:            http://pegasus.isi.edu/
Packager:       Pegasus Development Team <pegasus-support@isi.edu>

Source:         pegasus-%{version}.tar.gz

BuildRequires:  gcc, gcc-c++, make, cmake, openssl-devel, systemd-rpm-macros
Requires:       which, graphviz, %{?systemd_requires}

%global debug_package %{nil}

%if 0%{?rhel} == 8
BuildRequires:  java-17-openjdk-devel, python3.12-devel, python3.12-pip
Requires:       java-17-openjdk-headless, python3.12
%define pegasus_python 3.12
%endif

%if 0%{?rhel} == 9
BuildRequires:  java-21-openjdk-devel, python3.12-devel, python3.12-pip
Requires:       java-21-openjdk-headless, python3.12
%define pegasus_python 3.12
%endif

%if 0%{?rhel} == 10
BuildRequires:  java-21-openjdk-devel, python3-devel, python3-pip
Requires:       java-21-openjdk-headless, python3
%define pegasus_python 3.12
%endif

# Resolve site-packages path using the same prefix pip uses during %%install,
# so that %%files matches the actual install location.
%global python_sitearch %(/usr/bin/python%{pegasus_python} -c "import sysconfig; print(sysconfig.get_paths(vars={'base': '/usr', 'platbase': '/usr'})['platlib'])")

%define sourcedir %{name}-%{version}

# Disables the automatic dependency generator (we bundle deps inside the wheel)
%{?python_disable_dependency_generator}

# Turn off automatic Python bytecompilation
%undefine __brp_python_bytecompile

%description
The Pegasus project encompasses a set of technologies that
help workflow-based applications execute in a number of
different environments including desktops, campus clusters,
grids, and now clouds. Scientific workflows allow users to
easily express multi-step computations. Once an application
is formalized as a workflow the Pegasus Workflow Management
Service can map it onto available compute resources and
execute the steps in appropriate order.


%prep
%setup -q -n %{sourcedir}

%build
# Install build tooling into a temporary virtualenv (not available as distro packages)
/usr/bin/python%{pegasus_python} -m venv _build_venv
_build_venv/bin/pip install --upgrade pip scikit-build-core build

# Build the wheel (includes worker tarball + C tools + Java JARs via cmake)
PYTHON=$(pwd)/_build_venv/bin/python make build

%install
mkdir -p %{buildroot}%{_bindir} %{buildroot}%{python_sitearch}

/usr/bin/python%{pegasus_python} -m pip install \
    --ignore-installed \
    --root %{buildroot} \
    --prefix /usr \
    dist/pegasus_wms-*.whl

# Strip C executables
for bin in pegasus-kickstart pegasus-cluster pegasus-keg; do
    test -f %{buildroot}%{_bindir}/$bin && strip %{buildroot}%{_bindir}/$bin || true
done

# Install systemd service unit from source tree
install -d %{buildroot}%{_unitdir}
install -m 0644 share/pegasus/systemd-unit/pegasus-service.service \
    %{buildroot}%{_unitdir}/

# Remove pyc files and caches
find %{buildroot} -name "*.pyc" -delete
find %{buildroot} -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true

%files
%defattr(-,root,root,-)
%{_bindir}/*
%{python_sitearch}/Pegasus/
%{python_sitearch}/pegasus_wms-*.dist-info/
%{_unitdir}/pegasus-service.service

%post
systemctl daemon-reload >/dev/null 2>&1 || true

%preun
systemctl stop pegasus-service.service >/dev/null 2>&1 || true
systemctl disable pegasus-service.service >/dev/null 2>&1 || true
systemctl daemon-reload >/dev/null 2>&1 || true

%changelog
* @DATE@ Pegasus Development Team <pegasus-support@isi.edu> @PEGASUS_VERSION@
- @PEGASUS_VERSION@ automatic build

* Mon Dec 02 2013 Pegasus Development Team <pegasus-support@isi.edu> 4.3.2cvs
- Relaxed the "java" requirements in order for the package to work on plan
  CentOS machines
